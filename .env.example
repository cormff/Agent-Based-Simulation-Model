# --- Gemini (Cloud Ajanlar) ---
# Zorunlu: https://aistudio.google.com/app/apikey adresinden alınır.
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.9
GEMINI_MAX_CONCURRENCY=4

# --- Ollama (Edge / Yerel Game Master) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TEMPERATURE=0.85
OLLAMA_TIMEOUT=120

# --- Veritabanı ---
ABM_DB_PATH=simulation.db

# --- Simülasyon Parametreleri ---
ABM_MAX_ROUNDS=50
ABM_TRUST_THRESHOLD=25.0
ABM_INITIAL_TRUST=70.0
ABM_RECENT_LOG_LIMIT=6
ABM_RELATION_EDGE_THRESHOLD=0.5

# --- Yeniden Deneme / Backoff ---
ABM_MAX_RETRIES=5
ABM_BASE_RETRY_DELAY=1.5
ABM_MAX_RETRY_DELAY=30.0
ABM_MAX_JSON_REPAIR_ATTEMPTS=2
